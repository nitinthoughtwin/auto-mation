// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// PostgreSQL for Production (Vercel, Neon, Supabase, Prisma Data Platform, etc.)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Prisma Data Platform, both URLs are the same
  // For Neon/Vercel, you may need a separate direct URL for migrations
  directUrl = env("DIRECT_URL")
}

model Channel {
  id               String    @id @default(cuid())
  name             String
  youtubeChannelId String    @unique
  accessToken      String
  refreshToken     String
  uploadTime       String    @default("18:00")
  frequency        String    @default("daily")
  timezone         String    @default("Asia/Kolkata")
  isActive         Boolean   @default(true)
  lastUploadDate   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  videos           Video[]
}

model Video {
  id                     String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?
  tags                  String    @default("")
  fileName              String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  thumbnailName         String?
  thumbnailOriginalName String?
  thumbnailSize         Int?
  status                String    @default("queued")
  uploadedAt            DateTime?
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([channelId])
  @@index([status])
}

model SchedulerLog {
  id        String   @id @default(cuid())
  channelId String
  videoId   String?
  action    String
  status    String
  message   String?
  createdAt DateTime @default(now())

  @@index([channelId])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}
