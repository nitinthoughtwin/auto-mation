// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Channel {
  id               String    @id @default(cuid())
  name             String
  youtubeChannelId String    @unique
  accessToken      String
  refreshToken     String
  uploadTime       String    @default("18:00")
  frequency        String    @default("daily")
  isActive         Boolean   @default(true)
  lastUploadDate   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  videos           Video[]
}

model Video {
  id                     String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?
  tags                  String    @default("")
  fileName              String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  thumbnailName         String?   // Thumbnail file name (optional)
  thumbnailOriginalName String?   // Original thumbnail file name
  thumbnailSize         Int?      // Thumbnail file size
  status                String    @default("queued")
  uploadedAt            DateTime?
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model SchedulerLog {
  id          String   @id @default(cuid())
  channelId   String
  videoId     String?
  action      String
  status      String
  message     String?
  createdAt   DateTime @default(now())
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
