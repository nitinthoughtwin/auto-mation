generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Prisma Data Platform, both URLs are the same
  // For Neon/Vercel, you may need a separate direct URL for migrations
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  channels      Channel[]
  sessions      Session[]
  subscriptions Subscription[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Channel {
  id                 String    @id @default(cuid())
  userId             String?
  name               String
  youtubeChannelId   String    @unique
  googleAccountId    String?
  accessToken        String
  refreshToken       String
  uploadTime         String    @default("18:00")
  frequency          String    @default("daily")
  timezone           String    @default("Asia/Kolkata")
  isActive           Boolean   @default(true)
  lastUploadDate     DateTime?
  randomDelayMinutes Int?
  randomDelayDate    DateTime?
  privacyStatus      String    @default("public")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User?     @relation(fields: [userId], references: [id])
  videos             Video[]
}

model Video {
  id                    String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?
  tags                  String    @default("")
  fileName              String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  driveFileId           String?
  driveWebViewLink      String?
  status                String    @default("queued")
  uploadedAt            DateTime?
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  thumbnailName         String?
  thumbnailOriginalName String?
  thumbnailSize         Int?
  thumbnailDriveId      String?
  uploadedVideoId       String?
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

model SchedulerLog {
  id        String   @id @default(cuid())
  channelId String
  videoId   String?
  action    String
  status    String
  message   String?
  createdAt DateTime @default(now())
}

model Plan {
  id                    String         @id @default(cuid())
  name                  String         @unique
  displayName           String
  description           String?
  priceINR              Int            @default(0)
  priceUSD              Int            @default(0)
  yearlyPriceINR        Int            @default(0)
  yearlyPriceUSD        Int            @default(0)
  yearlyDiscountPercent Int?
  maxVideosPerMonth     Int            @default(10)
  maxChannels           Int            @default(1)
  maxStorageMB          Int            @default(500)
  aiCreditsPerMonth     Int            @default(10)
  maxVideoSizeMB        Int            @default(100)
  features              String
  isActive              Boolean        @default(true)
  sortOrder             Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  subscriptions         Subscription[]
}

model Subscription {
  id                     String    @id @default(cuid())
  userId                 String
  planId                 String
  status                 String    @default("active")
  currentPeriodStart     DateTime  @default(now())
  currentPeriodEnd       DateTime
  trialEndsAt            DateTime?
  cancelledAt            DateTime?
  cancelAtPeriodEnd      Boolean   @default(false)
  razorpaySubscriptionId String?
  razorpayPlanId         String?
  stripeSubscriptionId   String?
  stripePlanId           String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  payments               Payment[]
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   Plan      @relation(fields: [planId], references: [id])
  usage                  Usage?
}

model Payment {
  id                    String       @id @default(cuid())
  subscriptionId        String
  amount                Int
  currency              String       @default("INR")
  status                String       @default("pending")
  paymentMethod         String?
  razorpayOrderId       String?
  razorpayPaymentId     String?
  razorpaySignature     String?
  stripePaymentIntentId String?
  invoiceNumber         String?
  invoiceUrl            String?
  gstAmount             Int?
  gstPercentage         Float?       @default(18.0)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  subscription          Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Usage {
  id                String       @id @default(cuid())
  subscriptionId    String       @unique
  videosUploaded    Int          @default(0)
  videosThisMonth   Int          @default(0)
  channelsConnected Int          @default(0)
  storageUsedMB     Float        @default(0)
  aiCreditsUsed     Int          @default(0)
  lastResetAt       DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  subscription      Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

// Video Library Category - Admin creates categories with drive URLs
model VideoCategory {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  thumbnailUrl String?       // Optional thumbnail image URL for the category
  driveUrl     String        // Google Drive folder URL
  folderId     String?       // Extracted folder ID from URL
  isActive     Boolean       @default(true)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  videos       LibraryVideo[]

  @@map("video_categories")
}

// Videos fetched from Google Drive folders
model LibraryVideo {
  id             String         @id @default(cuid())
  categoryId     String
  driveFileId    String         @unique
  name           String
  mimeType       String
  size             Int?
  durationMillis   Int?          // Video duration in milliseconds (null = not yet fetched)
  thumbnailLink    String?
  webViewLink      String?
  downloadUrl      String?
  createdTime      DateTime?
  addedToQueue     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  category       VideoCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("library_videos")
}