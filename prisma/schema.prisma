// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Prisma Data Platform, both URLs are the same
  // For Neon/Vercel, you may need a separate direct URL for migrations
  directUrl = env("DIRECT_URL")
}

// User table (keep your existing users)
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  emailVerified DateTime?
  image        String?
  password     String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  accounts     Account[]
  sessions     Session[]
  channels     Channel[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// YouTube Channel connected by user
model Channel {
  id               String    @id @default(cuid())
  userId           String?
  name             String
  youtubeChannelId String    @unique
  accessToken      String
  refreshToken     String
  uploadTime       String    @default("18:00")
  frequency        String    @default("daily")
  timezone         String    @default("Asia/Kolkata")
  isActive         Boolean   @default(true)
  lastUploadDate   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  videos           Video[]
}

// Video queue for YouTube uploads
model Video {
  id                    String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?   @db.Text
  tags                  String    @default("")
  fileName              String    @db.Text
  originalName          String?
  fileSize              Int?
  mimeType              String?
  thumbnailName         String?   @db.Text
  thumbnailOriginalName String?
  thumbnailSize         Int?
  status                String    @default("queued")
  uploadedAt            DateTime?
  uploadedVideoId       String?   // YouTube video ID after upload
  error                 String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// Scheduler logs
model SchedulerLog {
  id        String   @id @default(cuid())
  channelId String
  videoId   String?
  action    String
  status    String
  message   String?  @db.Text
  createdAt DateTime @default(now())
}