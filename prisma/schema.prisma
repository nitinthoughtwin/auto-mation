// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Prisma Data Platform, both URLs are the same
  // For Neon/Vercel, you may need a separate direct URL for migrations
  directUrl = env("DIRECT_URL")
}

// User table
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  emailVerified DateTime?
  image        String?
  password     String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  accounts     Account[]
  sessions     Session[]
  channels     Channel[]
  driveVideos  DriveVideo[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Channel - Multi-platform support (YouTube, Instagram, Facebook)
model Channel {
  id                  String    @id @default(cuid())
  userId              String?
  name                String
  platform            String    @default("youtube") // youtube, instagram, facebook
  youtubeChannelId    String?   @unique
  instagramAccountId  String?   @unique
  facebookPageId      String?   @unique
  facebookPageName    String?
  accessToken         String
  refreshToken        String
  uploadTime          String    @default("18:00")
  frequency           String    @default("daily")
  timezone            String    @default("Asia/Kolkata")
  isActive            Boolean   @default(true)
  lastUploadDate      DateTime?
  randomDelayMinutes  Int?      // Random delay max minutes (0-180)
  randomDelayDate     DateTime? // Date for which random delay was calculated
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  videos              Video[]
}

// Video queue for uploads
model Video {
  id                    String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?
  tags                  String    @default("")
  fileName              String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  driveFileId           String?   // Google Drive file ID for mapped videos
  driveWebViewLink      String?   // Google Drive web view link
  thumbnailName         String?
  thumbnailOriginalName String?
  thumbnailSize         Int?
  thumbnailDriveId      String?   // Google Drive thumbnail file ID
  status                String    @default("queued") // queued, uploading, uploaded, failed
  uploadedAt            DateTime?
  uploadedVideoId       String?   // Platform video ID after upload
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// Google Drive Video Mapping - Store mapped Drive videos
model DriveVideo {
  id            String   @id @default(cuid())
  userId        String
  channelId     String?  // Optional - if assigned to a channel
  driveFileId   String   @unique
  name          String
  mimeType      String
  webViewLink   String?
  thumbnailLink String?
  size          Int?
  createdTime   DateTime?
  addedToQueue  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Scheduler logs
model SchedulerLog {
  id        String   @id @default(cuid())
  channelId String
  videoId   String?
  action    String
  status    String
  message   String?
  createdAt DateTime @default(now())
}
