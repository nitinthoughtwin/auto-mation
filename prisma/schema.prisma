// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // For Prisma Data Platform, both URLs are the same
  // For Neon/Vercel, you may need a separate direct URL for migrations
  directUrl = env("DIRECT_URL")
}

// User table (keep your existing users)
model User {
  id           String   @id @default(cuid())
  name         String?
  email        String?  @unique
  emailVerified DateTime?
  image        String?
  password     String?
  role         String   @default("user")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  accounts     Account[]
  sessions     Session[]
  channels     Channel[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// YouTube Channel connected by user
model Channel {
  id               String    @id @default(cuid())
  userId           String?
  name             String
  platform         String    @default("youtube") // youtube, instagram, facebook
  // YouTube fields
  youtubeChannelId String?   @unique
  accessToken      String
  refreshToken     String
  // Platform-specific IDs
  instagramAccountId String?  @unique
  facebookPageId     String?  @unique
  facebookPageName   String?
  // Common settings
  uploadTime       String    @default("18:00")
  frequency        String    @default("daily")
  timezone         String    @default("Asia/Kolkata")
  isActive         Boolean   @default(true)
  lastUploadDate   DateTime?
  randomDelayMinutes Int?    // Random delay in minutes (-15 to +15)
  randomDelayDate  DateTime? // Date for which random delay was calculated
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  videos           Video[]
}

// Video queue for uploads (YouTube, Instagram, Facebook)
model Video {
  id                    String    @id @default(cuid())
  channelId             String
  title                 String
  description           String?
  tags                  String    @default("")
  fileName              String
  originalName          String?
  fileSize              Int?
  mimeType              String?
  thumbnailName         String?
  thumbnailOriginalName String?
  thumbnailSize         Int?
  // Google Drive file mapping
  googleDriveFileId     String?   @unique // If video already exists on Drive
  googleDriveUrl        String?   // Direct download URL
  // Status tracking
  status                String    @default("queued")
  platform              String    @default("youtube") // youtube, instagram, facebook
  uploadedAt            DateTime?
  uploadedVideoId       String?   // Platform video ID after upload
  error                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  channel               Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
}

// Scheduler logs
model SchedulerLog {
  id        String   @id @default(cuid())
  channelId String
  videoId   String?
  action    String
  status    String
  message   String?
  createdAt DateTime @default(now())
}
